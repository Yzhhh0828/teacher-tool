# ── App ──────────────────────────────────────────────────────────────
APP_NAME=Teacher Tool
APP_ENV=development          # development | production
DEBUG=true                   # Must be false in production

# ── Database ─────────────────────────────────────────────────────────
# SQLite (local dev, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./teacher_tool.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/teacher_tool

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
VERIFICATION_CODE_TTL_SECONDS=300
EXPOSE_DEBUG_VERIFICATION_CODE=true
DEV_FIXED_VERIFICATION_CODE=123456

# ── CORS ─────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=*       # Comma-separated list; cannot be * in production

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Storage ──────────────────────────────────────────────────────────
STORAGE_TYPE=local           # local | minio | oss
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teacher-tool
